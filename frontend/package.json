{
  "name": "demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/electron/main.cjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dev:desktop": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "build:desktop": "npm run build && electron-builder -w"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@stomp/stompjs": "^7.3.0",
    "@vueform/multiselect": "^2.6.11",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "html5-qrcode": "^2.3.8",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "material-icons": "^1.13.14",
    "nouislider": "^15.8.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "qrcode": "^1.5.4",
    "sockjs-client": "^1.6.1",
    "sweetalert2": "^11.26.18",
    "vnpay": "^2.4.4",
    "vue": "^3.5.26",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4",
    "vue-select": "^4.0.0-beta.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.demo.desktop",
    "productName": "Demo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
